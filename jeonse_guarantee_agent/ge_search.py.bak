import re
from typing import Any, Dict, List

from google.cloud import discoveryengine_v1 as discoveryengine


PROJECT_ID = "min-sung-jae-cloud"
LOCATION = "global"
APP_ID = "app-banking-advisory-app_1781761252022"
SERVING_CONFIG = (
    f"projects/{PROJECT_ID}/locations/{LOCATION}/collections/default_collection/"
    f"engines/{APP_ID}/servingConfigs/default_search"
)


def _strip_html(text: str) -> str:
    """Discovery Engine snippet/extractive answer에 포함된 <b> 태그 등을 제거합니다."""
    if not text:
        return ""
    text = re.sub(r"<[^>]+>", "", text)
    text = text.replace("&nbsp;", " ")
    text = text.replace("&amp;", "&")
    text = text.replace("&#39;", "'")
    return text.strip()


def _guess_doc_type(link: str, title: str) -> str:
    """GCS 경로 또는 title을 기반으로 문서 유형을 추정합니다."""
    combined = f"{link} {title}".lower()

    if "external_regulation" in combined:
        return "external_regulation"
    if "internal_policy" in combined:
        return "internal_policy"
    if "/qa/" in combined or "qa_" in combined:
        return "qa"

    return "unknown"


def _extract_effective_date(text: str) -> str:
    """문서 제목/경로/본문에서 YYYY-MM-DD 또는 YYYYMMDD 형태의 날짜 후보를 추출합니다."""
    if not text:
        return ""

    # YYYY-MM-DD
    match = re.search(r"(20\d{2})[-_.](0[1-9]|1[0-2])[-_.](0[1-9]|[12]\d|3[01])", text)
    if match:
        return f"{match.group(1)}-{match.group(2)}-{match.group(3)}"

    # YYYYMMDD
    match = re.search(r"(20\d{2})(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])", text)
    if match:
        return f"{match.group(1)}-{match.group(2)}-{match.group(3)}"

    return ""


def search_gemini_enterprise(query: str, page_size: int = 5) -> Dict[str, Any]:
    """
    Gemini Enterprise App 기준으로 연결된 Data Store를 검색합니다.
    반환값은 ADK Tool에서 쓰기 쉽게 짧게 정리합니다.
    """
    client = discoveryengine.SearchServiceClient()

    request = discoveryengine.SearchRequest(
        serving_config=SERVING_CONFIG,
        query=query,
        page_size=page_size,
        user_pseudo_id="adk-local-test",
        relevance_score_spec=discoveryengine.SearchRequest.RelevanceScoreSpec(
            return_relevance_score=True
        ),
        content_search_spec=discoveryengine.SearchRequest.ContentSearchSpec(
            snippet_spec=discoveryengine.SearchRequest.ContentSearchSpec.SnippetSpec(
                return_snippet=True
            ),
            extractive_content_spec=discoveryengine.SearchRequest.ContentSearchSpec.ExtractiveContentSpec(
                max_extractive_answer_count=3
            ),
        ),
    )

    response = client.search(request=request)

    results: List[Dict[str, Any]] = []

    for item in response.results:
        doc = item.document
        data = dict(doc.derived_struct_data)

        title = data.get("title", doc.id)
        link = data.get("link", "")

        snippets = []
        for snippet in data.get("snippets", []):
            if isinstance(snippet, dict):
                snippets.append(_strip_html(snippet.get("snippet", "")))

        extractive_answers = []
        for answer in data.get("extractive_answers", []):
            if isinstance(answer, dict):
                extractive_answers.append(_strip_html(answer.get("content", "")))

        combined_text = " ".join([title, link] + snippets + extractive_answers)
        doc_type = _guess_doc_type(link, title)
        effective_date = _extract_effective_date(combined_text)

        relevance_score = None
        try:
            score_values = item.model_scores["relevance_score"].values
            if score_values:
                relevance_score = score_values[0]
        except Exception:
            relevance_score = None

        results.append(
            {
                "document_id": doc.id,
                "title": title,
                "link": link,
                "document_type": doc_type,
                "effective_date_candidate": effective_date,
                "relevance_score": relevance_score,
                "snippets": snippets[:2],
                "extractive_answers": extractive_answers[:2],
            }
        )

    return {
        "query": query,
        "serving_config": SERVING_CONFIG,
        "result_count": len(results),
        "results": results,
    }


if __name__ == "__main__":
    import json
    import sys

    q = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else "외국인 임대인 HUG 전세보증"
    print(json.dumps(search_gemini_enterprise(q), ensure_ascii=False, indent=2))
