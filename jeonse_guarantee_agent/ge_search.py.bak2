import html
import json
import re
from typing import Any, Dict, List

from google.cloud import discoveryengine_v1 as discoveryengine
from google.protobuf import struct_pb2
from google.protobuf.json_format import MessageToDict


PROJECT_ID = "min-sung-jae-cloud"
LOCATION = "global"
APP_ID = "app-banking-advisory-app_1781761252022"
SERVING_CONFIG = (
    f"projects/{PROJECT_ID}/locations/{LOCATION}/collections/default_collection/"
    f"engines/{APP_ID}/servingConfigs/default_search"
)


def _strip_html(text: str) -> str:
    """snippet/extractive answer의 HTML 태그와 entity를 제거합니다."""
    if not text:
        return ""

    text = html.unescape(text)
    text = re.sub(r"<[^>]+>", "", text)
    text = re.sub(r"\s+", " ", text)
    return text.strip()


def _proto_value_to_python(value: Any) -> Any:
    """
    protobuf Struct/Value/ListValue를 일반 Python dict/list/str로 변환합니다.
    Discovery Engine derived_struct_data의 중첩 구조를 안전하게 다루기 위한 함수입니다.
    """
    if hasattr(value, "_pb"):
        value = value._pb

    if isinstance(value, struct_pb2.Value):
        kind = value.WhichOneof("kind")

        if kind == "null_value":
            return None
        if kind == "number_value":
            return value.number_value
        if kind == "string_value":
            return value.string_value
        if kind == "bool_value":
            return value.bool_value
        if kind == "struct_value":
            return _proto_value_to_python(value.struct_value)
        if kind == "list_value":
            return _proto_value_to_python(value.list_value)

        return None

    if isinstance(value, struct_pb2.Struct):
        return {k: _proto_value_to_python(v) for k, v in value.fields.items()}

    if isinstance(value, struct_pb2.ListValue):
        return [_proto_value_to_python(v) for v in value.values]

    if isinstance(value, dict):
        return {k: _proto_value_to_python(v) for k, v in value.items()}

    if isinstance(value, list):
        return [_proto_value_to_python(v) for v in value]

    return value


def _struct_to_dict(struct_data: Any) -> Dict[str, Any]:
    """derived_struct_data를 일반 dict로 변환합니다."""
    try:
        raw = struct_data._pb if hasattr(struct_data, "_pb") else struct_data
        converted = MessageToDict(raw, preserving_proto_field_name=True)
        if isinstance(converted, dict):
            return converted
    except Exception:
        pass

    try:
        return _proto_value_to_python(struct_data)
    except Exception:
        pass

    try:
        return dict(struct_data)
    except Exception:
        return {}


def _guess_doc_type(link: str, title: str) -> str:
    """GCS 경로 또는 title을 기반으로 문서 유형을 추정합니다."""
    combined = f"{link} {title}".lower()

    if "external_regulation" in combined:
        return "external_regulation"
    if "internal_policy" in combined:
        return "internal_policy"
    if "/qa/" in combined or "qa_" in combined:
        return "qa"

    return "unknown"


def _extract_effective_date(text: str) -> str:
    """문서 제목/경로/본문에서 YYYY-MM-DD 또는 YYYYMMDD 형태의 날짜 후보를 추출합니다."""
    if not text:
        return ""

    match = re.search(r"(20\d{2})[-_.](0[1-9]|1[0-2])[-_.](0[1-9]|[12]\d|3[01])", text)
    if match:
        return f"{match.group(1)}-{match.group(2)}-{match.group(3)}"

    match = re.search(r"(20\d{2})(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])", text)
    if match:
        return f"{match.group(1)}-{match.group(2)}-{match.group(3)}"

    return ""


def _extract_text_list(data: Dict[str, Any], key: str) -> List[str]:
    """
    snippets 또는 extractive_answers에서 텍스트를 추출합니다.
    Discovery Engine 응답은 list[dict] 형태로 오는 경우가 많습니다.
    """
    items = data.get(key, [])
    texts: List[str] = []

    if not isinstance(items, list):
        return texts

    for item in items:
        if isinstance(item, dict):
            candidate = (
                item.get("content")
                or item.get("snippet")
                or item.get("answer")
                or item.get("text")
                or ""
            )
        elif isinstance(item, str):
            candidate = item
        else:
            candidate = ""

        cleaned = _strip_html(candidate)
        if cleaned:
            texts.append(cleaned)

    return texts


def search_gemini_enterprise(query: str, page_size: int = 5) -> Dict[str, Any]:
    """
    Gemini Enterprise App 기준으로 연결된 Data Store를 검색합니다.
    반환값은 ADK Tool에서 쓰기 쉽게 짧게 정리합니다.
    """
    client = discoveryengine.SearchServiceClient()

    request = discoveryengine.SearchRequest(
        serving_config=SERVING_CONFIG,
        query=query,
        page_size=page_size,
        user_pseudo_id="adk-local-test",
        relevance_score_spec=discoveryengine.SearchRequest.RelevanceScoreSpec(
            return_relevance_score=True
        ),
        content_search_spec=discoveryengine.SearchRequest.ContentSearchSpec(
            snippet_spec=discoveryengine.SearchRequest.ContentSearchSpec.SnippetSpec(
                return_snippet=True
            ),
            extractive_content_spec=discoveryengine.SearchRequest.ContentSearchSpec.ExtractiveContentSpec(
                max_extractive_answer_count=3
            ),
        ),
    )

    response = client.search(request=request)
    results: List[Dict[str, Any]] = []

    for item in response.results:
        doc = item.document
        data = _struct_to_dict(doc.derived_struct_data)

        title = data.get("title", doc.id)
        link = data.get("link", "")

        snippets = _extract_text_list(data, "snippets")
        extractive_answers = _extract_text_list(data, "extractive_answers")

        combined_text = " ".join([title, link] + snippets + extractive_answers)
        doc_type = _guess_doc_type(link, title)
        effective_date = _extract_effective_date(combined_text)

        relevance_score = None
        try:
            score_values = item.model_scores["relevance_score"].values
            if score_values:
                relevance_score = score_values[0]
        except Exception:
            relevance_score = None

        results.append(
            {
                "document_id": doc.id,
                "title": title,
                "link": link,
                "document_type": doc_type,
                "effective_date_candidate": effective_date,
                "relevance_score": relevance_score,
                "snippets": snippets[:2],
                "extractive_answers": extractive_answers[:2],
            }
        )

    return {
        "query": query,
        "serving_config": SERVING_CONFIG,
        "result_count": len(results),
        "results": results,
    }


if __name__ == "__main__":
    import sys

    q = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else "외국인 임대인 HUG 전세보증"
    print(json.dumps(search_gemini_enterprise(q), ensure_ascii=False, indent=2))
